{
  "name": "gitpal",
  "displayName": "GitPal",
  "description": "A beginner-friendly plain-English Git assistant for VS Code.",
  "version": "0.0.1",
  "publisher": "nsw-marketplace",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Education",
    "Other"
  ],
  "keywords": [
    "git",
    "beginner",
    "learning",
    "version-control",
    "assistant",
    "vscode",
    "workflow"
  ],
  "preview": true,
  "pricing": "Free",
  "icon": "media/gitpal-icon.png",
  "galleryBanner": {
    "color": "#1f2937",
    "theme": "dark"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tanisqgg/gitpal.git"
  },
  "homepage": "https://github.com/Tanisqgg/gitpal#readme",
  "bugs": {
    "url": "https://github.com/Tanisqgg/gitpal/issues"
  },
  "activationEvents": [
    "onCommand:gitpal.open",
    "onView:gitpal.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitpal.open",
        "title": "GitPal: Open"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitpal",
          "title": "GitPal",
          "icon": "media/gitpal.svg"
        }
      ]
    },
    "views": {
      "gitpal": [
        {
          "id": "gitpal.sidebar",
          "name": "GitPal Assistant",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
